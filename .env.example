OPENCLAW_FINANCE_HOME=~/openclaw-finance
PORTFOLIO_FILE=~/openclaw-finance/portfolio.json
CHART_DIR=~/openclaw-finance/charts
DATA_DIR=~/openclaw-finance/data

QWEN_BASE_URL=http://127.0.0.1:11434/v1
QWEN_MODEL=qwen2.5:14b-instruct
QWEN_API_KEY=EMPTY
QWEN_TIMEOUT=120

LOG_LEVEL=INFO

# Candidate scoring weights (auto-normalized, must be >= 0)
SCORE_WEIGHT_TREND=0.35
SCORE_WEIGHT_VOLUME_PRICE=0.30
SCORE_WEIGHT_VOLATILITY=0.15
SCORE_WEIGHT_TURNOVER=0.20
